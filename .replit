modules = ["python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Tests & Pipeline"

[[workflows.workflow]]
name = "Run Tests & Pipeline"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest -q && python -m core.pipeline --limit 3"

[workflows.workflow.metadata]
outputType = "console"
